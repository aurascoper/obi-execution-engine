# ── Credentials & local config (NEVER commit) ─────────────────────────────────
env.sh
.env
*.env
.env.*
!.env.example

# ── Runtime logs (can be large) ───────────────────────────────────────────────
logs/*
!logs/.gitkeep

# ── Python artifacts ──────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# ── Build / distribution ──────────────────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.Python

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Claude Code local state (not for commit) ──────────────────────────────────
.claude/

# ── ML artifacts (Phase 6+) ───────────────────────────────────────────────────
