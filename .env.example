# Copy this file to .env and fill in the credentials.
# All engines load .env automatically via config.settings.

# ── Execution mode ────────────────────────────────────────────────────────
# PAPER = simulated orders, SHADOW = no orders hit the wire, LIVE = real $.
EXECUTION_MODE=PAPER
ALPACA_TRADING_MODE=paper

# ── Alpaca (equities + crypto spot) ──────────────────────────────────────
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# Live-mode Alpaca keys (only used when ALPACA_TRADING_MODE=live).
ALPACA_API_KEY_LIVE=
ALPACA_API_SECRET_LIVE=

# ── Hyperliquid (perps) ──────────────────────────────────────────────────
# Master wallet address + key. Agent keys cannot do USD transfers.
HL_WALLET_ADDRESS=
HL_PRIVATE_KEY=

# ── Hyperliquid universe (optional — sensible defaults exist) ────────────
# Native HL perps — comma-separated.
HL_UNIVERSE=BTC,ETH,SOL,AAVE,XRP,DOGE,LINK,ADA,AVAX
# Builder-deployed DEXs (HIP-3 equity/commodity perps) to subscribe to.
HIP3_DEXS=xyz
# Per-DEX symbol list, prefixed "<dex>:<SYMBOL>".
HIP3_UNIVERSE=xyz:HIMS,xyz:HOOD,xyz:COIN,xyz:MSTR
HIP3_LEVERAGE=10
EXECUTION_STYLE=maker

# ── Windows-only (optional) ──────────────────────────────────────────────
# Override where engine control sockets live. Default is %TEMP% on Windows,
# /tmp on POSIX. Only useful for ops tooling (hl_ctl.py, webhook_server.py).
# HL_CONTROL_DIR=C:\Users\you\AppData\Local\Temp
